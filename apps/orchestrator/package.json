{
  "name": "@research-agent/orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Research Agent Orchestrator - Tool selection, synthesis, and audit",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "npm run build && node dist/api-server.js",
    "start:dev": "tsc --watch & node --watch dist/api-server.js",
    "demo": "npm run build && node dist/demo.js",
    "demo:audit": "npm run build && node dist/audit-demo.js",
    "test": "vitest run",
    "test:ci": "vitest run",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@research-agent/clinicaltrials-mcp": "*",
    "@research-agent/m365-mail-mcp": "*",
    "@research-agent/memory-mcp": "*",
    "@research-agent/pubmed-mcp": "*",
    "@research-agent/web-mcp": "*",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.6.0"
  }
}
