# Azure OpenAI — authentication uses DefaultAzureCredential (no API key needed).
# Copy this file to .env and fill in the endpoint and deployment name.
#
# Authentication (no key required):
#   Local development: run `az login` or `azd auth login` once — credential is picked up automatically.
#   Azure deployment:  Container App uses Managed Identity automatically.
#
# To find these values:
#   1. Go to Azure Portal → your Azure OpenAI resource
#   2. Keys and Endpoint → copy the Endpoint URL
#   3. Azure AI Foundry → Deployments → copy your deployment name

# Full endpoint URL, e.g. https://my-resource.cognitiveservices.azure.com/
AZURE_OPENAI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/

# Name of your gpt-4o deployment (as shown in Azure AI Foundry → Deployments)
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# API version — use 2024-10-01-preview for cognitiveservices.azure.com endpoints
AZURE_OPENAI_API_VERSION=2024-10-01-preview

# AZURE_OPENAI_KEY is no longer used — remove it if present in your .env

# Bing Search — also uses DefaultAzureCredential (bearer token), no API key needed.
# Requires the logged-in user / Managed Identity to have access to the Bing Search resource.
# BING_SEARCH_API_KEY is no longer used — remove it if present in your .env

# CORS origin — defaults to http://localhost:5173 for local development
# Set automatically in Azure via Bicep (no need to set manually in production)
# CORS_ORIGIN=https://stapp-xxxxx.azurestaticapps.net
