# Azure OpenAI — authentication uses DefaultAzureCredential (no API key needed).
# Copy this file to .env and fill in the values below.
#
# Azure OpenAI authentication (no key required):
#   Local development: run `az login` or `azd auth login` once — credential is picked up automatically.
#   Azure deployment:  Container App uses Managed Identity automatically.
#
# To find your Azure OpenAI values:
#   1. Go to Azure Portal → your Azure OpenAI resource
#   2. Keys and Endpoint → copy the Endpoint URL
#   3. Azure AI Foundry → Deployments → copy your deployment name

# Full endpoint URL, e.g. https://my-resource.cognitiveservices.azure.com/
AZURE_OPENAI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/

# Name of your gpt-4o deployment (as shown in Azure AI Foundry → Deployments)
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# API version — 2024-12-01-preview or later recommended (required for response_format: json_object)
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# AZURE_OPENAI_KEY is no longer used — remove it if present in your .env

# ── Web Search (Tavily) ──────────────────────────────────────────────────────
# Required for regulatory/news/recent-events queries (web-search tool).
# Free tier: 1,000 searches/month, no credit card — sign up at https://app.tavily.com/
# Without this, open-ended regulatory queries fall back to PubMed only.
TAVILY_API_KEY=<your-tavily-api-key>

# CORS origin — defaults to http://localhost:5173 for local development
# Set automatically in Azure via Bicep (no need to set manually in production)
# CORS_ORIGIN=https://stapp-xxxxx.azurestaticapps.net

# ── Research Memory (Cosmos DB) ──────────────────────────────────────────────
# Cosmos DB persists research memory entries across server restarts.
# Authentication uses DefaultAzureCredential — no connection string or key needed.
#
#   Local development:
#     1. Run `az login` once (same credential used for Azure OpenAI)
#     2. In Azure Portal → your Cosmos DB account → Settings → Keys → copy the URI
#     3. Grant yourself the "Cosmos DB Built-in Data Contributor" role:
#          az cosmosdb sql role assignment create \
#            --account-name <cosmos-account> \
#            --resource-group <rg> \
#            --role-definition-name "Cosmos DB Built-in Data Contributor" \
#            --principal-id $(az ad signed-in-user show --query id -o tsv) \
#            --scope "/"
#
#   Azure deployment: provisioned and wired automatically by `azd up`.
#     The Container App's managed identity is granted the role via Bicep.
#
# Leave unset to use the in-memory store (data lost on restart — fine for local testing).
# COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/

# Cosmos DB database name (default: research-agent — no need to change)
# COSMOS_DATABASE=research-agent
